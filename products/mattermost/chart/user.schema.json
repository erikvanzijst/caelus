{
  "type": "object",
  "properties": {
    "host": {
      "type": "string",
      "title": "hostname",
      "description": "The public hostname where Mattermost will be accessible.",
      "minLength": 1,
      "maxLength": 64
    },
    "mattermost": {
      "type": "object",
      "properties": {
        "extraEnv": {
          "type": "object",
          "properties": {
            "TZ": {
              "type": "string",
              "title": "Timezone",
              "description": "IANA timezone for Mattermost (e.g. Europe/Amsterdam, America/New_York).",
              "default": "Europe/Amsterdam"
            }
          }
        }
      }
    }
  },
  "required": ["host"]
}
